# Fleet simulation parameters
FLEET_SIZE=15

# Geographic bounding box — defaults to Warsaw city area
BBOX_LAT_MIN=52.10
BBOX_LAT_MAX=52.35
BBOX_LNG_MIN=20.85
BBOX_LNG_MAX=21.25

# Simulation update interval in milliseconds
UPDATE_INTERVAL_MS=1000

# CORS — must match the visualisation origin
CORS_ORIGIN=http://localhost:3000

# Visualisation — URL of the mock-api (used inside Docker as service name)
NEXT_PUBLIC_API_URL=http://localhost:3001
